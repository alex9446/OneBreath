# default, always check if it is still valid
/*
  cache-control: public,max-age=0,must-revalidate

# assets, contain fingerprints, 1 year, immutable
/assets/*
  cache-control: public,max-age=31536000,immutable

# fonts - images - reset, rarely change, 1 hour, 1 week
/fonts/*
  cache-control: public,max-age=3600,stale-while-revalidate=604800
/images/*
  cache-control: public,max-age=3600,stale-while-revalidate=604800
/reset.css
  cache-control: public,max-age=3600,stale-while-revalidate=604800
